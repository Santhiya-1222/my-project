<%- include("partials/layout", { title: "Admin Dashboard", body: `
  <div class="d-flex align-items-end justify-content-between gap-3 flex-wrap mb-3">
    <div>
      <div class="page-title">Dashboard</div>
      <div class="text-muted">Overview</div>
    </div>
  </div>

  <div class="row g-3 mb-5">
    <div class="col-12">
      <div class="stat-card shadow-eatclub">
        <div class="stat-card__icon">🛒</div>
        <div class="stat-card__value">${Number(totalOrders || 0)}</div>
        <div class="stat-card__label">Total Orders</div>
      </div>
    </div>
    <div class="col-12">
      <div class="stat-card shadow-eatclub">
        <div class="stat-card__icon">₹</div>
        <div class="stat-card__value">₹${Number(todaysRevenue || 0).toFixed(0)}</div>
        <div class="stat-card__label">Today's Revenue</div>
      </div>
    </div>
    <div class="col-12">
      <div class="stat-card shadow-eatclub">
        <div class="stat-card__icon">🍽</div>
        <div class="stat-card__value">${Number(activeItems || 0)}</div>
        <div class="stat-card__label">Active Items</div>
      </div>
    </div>
  </div>

  ${include("partials/admin-nav", { active: "dashboard" })}
` }) %>

