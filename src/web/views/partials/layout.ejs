<!doctype html>
<html lang="en" data-bs-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title || "EatClub" %></title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/static/styles.css" />
  </head>
  <body class="bg-eatclub">
    <nav class="navbar navbar-expand-lg navbar-dark nav-eatclub sticky-top">
      <div class="container">
        <a class="navbar-brand fw-semibold d-flex align-items-center gap-2" href="/">
          <span class="brand-mark">🍽</span>
          <span>Campus Food Court</span>
        </a>
        <div class="ms-auto d-flex align-items-center gap-2">
          <span class="badge status-pill <%= ordering?.isOrderingOpen ? 'text-bg-success' : 'text-bg-danger' %>">
            <%= ordering?.isOrderingOpen ? 'Open' : 'Closed' %>
          </span>
          <% if (user) { %>
            <span class="text-white-50 small">Signed in as <strong class="text-white"><%= user.username %></strong> (<%= user.role %>)</span>
            <form method="post" action="/logout" class="d-inline">
              <button class="btn btn-sm btn-outline-light" type="submit">Logout</button>
            </form>
          <% } %>
        </div>
      </div>
    </nav>
    <main class="container py-4 pb-6">
      <%- body %>
    </main>

    <script>
      (function () {
        const CART_KEY = "eatclub_cart_v1";

        function readCart() {
          try {
            const raw = localStorage.getItem(CART_KEY);
            if (!raw) return { items: {} };
            const parsed = JSON.parse(raw);
            if (!parsed || typeof parsed !== "object") return { items: {} };
            if (!parsed.items || typeof parsed.items !== "object") return { items: {} };
            return parsed;
          } catch (e) {
            return { items: {} };
          }
        }

        function cartCount() {
          const cart = readCart();
          return Object.values(cart.items).reduce((sum, n) => sum + Number(n || 0), 0);
        }

        function updateBadge() {
          const el = document.getElementById("cartBadge");
          if (!el) return;
          const c = cartCount();
          el.textContent = String(c);
          el.style.display = c > 0 ? "" : "none";
        }

        window.EatClubCart = {
          CART_KEY,
          readCart,
          writeCart(next) {
            localStorage.setItem(CART_KEY, JSON.stringify(next));
            updateBadge();
          },
          setItem(itemId, qty) {
            const cart = readCart();
            const id = String(itemId);
            if (!cart.items) cart.items = {};
            if (qty <= 0) delete cart.items[id];
            else cart.items[id] = qty;
            this.writeCart(cart);
          },
          getItemQty(itemId) {
            const cart = readCart();
            return Number(cart.items[String(itemId)] || 0);
          },
        };

        updateBadge();
        window.addEventListener("storage", updateBadge);
      })();
    </script>
  </body>
</html>

