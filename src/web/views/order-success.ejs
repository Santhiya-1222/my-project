<%- include("partials/layout", { title: "Order placed", body: `
  <div class="card shadow-sm">
    <div class="card-body">
      <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
          <h1 class="h4 mb-1">Order placed</h1>
          <div class="text-muted">Your order has been saved.</div>
        </div>
        <a class="btn btn-outline-primary" href="/orders">View my orders</a>
      </div>

      <hr class="my-3" />

      <div class="row g-3">
        <div class="col-12 col-md-6">
          <div class="p-3 rounded bg-body-tertiary">
            <div class="small text-muted">Item</div>
            <div class="fw-semibold">${order.item_name}</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="p-3 rounded bg-body-tertiary">
            <div class="small text-muted">Qty</div>
            <div class="fw-semibold">${order.quantity}</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="p-3 rounded bg-body-tertiary">
            <div class="small text-muted">Total</div>
            <div class="fw-semibold">₹${Number(order.total_price).toFixed(0)}</div>
          </div>
        </div>
        <div class="col-12 col-md-6">
          <div class="p-3 rounded bg-body-tertiary">
            <div class="small text-muted">Payment</div>
            <div class="fw-semibold">${order.pay_method === "online" ? "Online (simulated)" : "Offline"}</div>
            ${order.payment_ref ? `<div class="small text-muted">Ref: <code>${order.payment_ref}</code></div>` : ""}
          </div>
        </div>
        <div class="col-12 col-md-6">
          <div class="p-3 rounded bg-body-tertiary">
            <div class="small text-muted">Time</div>
            <div class="fw-semibold">${order.created_at}</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-3 d-flex gap-2">
    <a class="btn btn-primary" href="/menu">Back to menu</a>
    <form method="post" action="/logout">
      <button class="btn btn-outline-secondary" type="submit">Logout</button>
    </form>
  </div>

  <script>
    try {
      localStorage.removeItem("eatclub_cart_v1");
    } catch (e) {}
  </script>
` }) %>

