<%- include("partials/layout", { title: "Admin", body: `
  <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap mb-3">
    <div>
      <h1 class="h4 mb-1">Admin dashboard</h1>
      <div class="text-muted">Add/delete items, set availability, and change prices.</div>
    </div>
    <div class="d-flex gap-2">
      <a class="btn btn-outline-primary" href="/admin/orders">View orders</a>
    </div>
  </div>

  <div class="card shadow-sm mb-3">
    <div class="card-body">
      <h2 class="h6 mb-3">Add new food item</h2>
      <form method="post" action="/admin/item/add" class="row g-2 align-items-end">
        <div class="col-12 col-md-4">
          <label class="form-label">Name</label>
          <input class="form-control" name="name" placeholder="e.g., Veg Fried Rice" required />
        </div>
        <div class="col-12 col-md-3">
          <label class="form-label">Meal</label>
          <select class="form-select" name="meal" required>
            <option value="afternoon">Afternoon</option>
            <option value="evening">Evening</option>
          </select>
        </div>
        <div class="col-12 col-md-3">
          <label class="form-label">Price (₹)</label>
          <input class="form-control" type="number" step="1" min="0" name="price" required />
        </div>
        <div class="col-12 col-md-2">
          <div class="form-check">
            <input class="form-check-input" type="checkbox" name="available" id="availableNew" checked />
            <label class="form-check-label" for="availableNew">Available</label>
          </div>
          <button class="btn btn-primary w-100 mt-2" type="submit">Add</button>
        </div>
      </form>
    </div>
  </div>

  <div class="card shadow-sm">
    <div class="card-body">
      <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
        <h2 class="h6 mb-0">All items</h2>
        <span class="text-muted small">Tip: uncheck “Available” to hide from student ordering.</span>
      </div>

      <div class="table-responsive">
        <table class="table align-middle mb-0">
          <thead>
            <tr>
              <th>Meal</th>
              <th>Item</th>
              <th class="text-end">Price (₹)</th>
              <th>Available</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            ${(items || []).map(i => `
              <tr>
                <td><span class="badge ${i.meal === "afternoon" ? "text-bg-info" : "text-bg-warning"}">${i.meal}</span></td>
                <td class="fw-semibold">${i.name}</td>
                <td class="text-end">
                  <form method="post" action="/admin/item/update" class="d-flex justify-content-end gap-2 align-items-center">
                    <input type="hidden" name="id" value="${i.id}" />
                    <input class="form-control form-control-sm" style="max-width:110px" type="number" step="1" min="0" name="price" value="${Number(i.price).toFixed(0)}" required />
                </td>
                <td>
                    <div class="form-check m-0">
                      <input class="form-check-input" type="checkbox" name="available" ${i.available ? "checked" : ""} />
                      <label class="form-check-label small text-muted">Available</label>
                    </div>
                </td>
                <td class="text-end">
                    <button class="btn btn-sm btn-outline-primary" type="submit">Save</button>
                  </form>
                  <form method="post" action="/admin/item/delete" class="d-inline">
                    <input type="hidden" name="id" value="${i.id}" />
                    <button class="btn btn-sm btn-outline-danger" type="submit" onclick="return confirm('Delete this item?')">Delete</button>
                  </form>
                </td>
              </tr>
            `).join("")}
          </tbody>
        </table>
      </div>
    </div>
  </div>
` }) %>

